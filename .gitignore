# Obsidian vault config — editor-local (created by the excalidraw skill)
.obsidian/

# Project's own dogfooded context. core/ + knowledge/ are kept tracked as a
# curated public showcase of what a mature dreamcontext looks like. These
# directories are internal working data — tracked locally so the tool keeps
# working, but kept OUT of the public repo:
#   marketing/ — scraped third-party competitor data (copyright/ToS) + strategy
#   state/     — raw task PRDs / unreleased-roadmap working notes (+ ephemeral
#                .sleep.json, .version-check.json, .session-digests/)
#   council/   — internal decision debates
_dream_context/marketing/
_dream_context/state/
_dream_context/council/
# Ephemeral runtime scratch — images dropped into the in-app agent, etc. Never tracked.
_dream_context/tmp/
# Secrets are never tracked, regardless of the above
_dream_context/**/.env
# Lab (analytics insights) credentials — insights + cache DO sync, only this doesn't
_dream_context/lab/credentials.json
_dream_context/lab/credentials.*
# design-sync: staged converter scripts, build output, machine state (durable
# inputs — config.json, NOTES.md, conventions.md, previews/, overrides/ — stay tracked)
.ds-sync/
ds-bundle/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules

# Playwright
test-results/
playwright-report/
e2e/shots/
.playwright/
.playwright-mcp/
.codex/

# Local verification screenshots
version-filter-sprint-aware.png

# Scratch downloads (videos, transcripts, media pulled for analysis)
_download/
docs/

# dreamcontext remote task backend (derived mirror + sync state)
_dream_context/state/*.md
_dream_context/state/.tasks-sync.lock
_dream_context/state/.tasks-sync.json
_dream_context/state/.tasks-queue.json
_dream_context/state/.conflicts/
_dream_context/state/.secrets.json

# dreamcontext: machine-local agent session roster (Claude resume ids)
_dream_context/state/.agent-sessions.json

# dreamcontext: machine-local agent tab → live Claude session map (one file per tab)
_dream_context/state/.agent-session-map/
