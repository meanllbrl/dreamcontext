{
  "name": "dreamcontext",
  "version": "0.17.1",
  "description": "dreamcontext — the persistent brain for your AI agents. Remembers what you built, knows how your project works.",
  "type": "module",
  "bin": {
    "dreamcontext": "./dist/index.js"
  },
  "files": [
    "dist",
    "skill",
    "skill-initializer",
    "skill-curator",
    "skill-deep-research",
    "skill-sync",
    "skill-packs",
    "agents",
    "README.md",
    "LICENSE",
    "NOTICE",
    "install.sh"
  ],
  "scripts": {
    "build:dashboard": "cd dashboard && npm run build",
    "build:cli": "tsup",
    "build": "npm run build:dashboard && npm run build:cli",
    "dev": "tsup --watch",
    "dev:dashboard": "cd dashboard && npm run dev",
    "test": "vitest",
    "test:e2e": "playwright test",
    "diagrams": "node scripts/diagrams/build-all.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "context",
    "memory",
    "brain",
    "cli",
    "claude",
    "gemini",
    "llm"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "nanoid": "^5.1.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.13.4",
    "@types/ws": "^8.18.1",
    "sharp": "^0.34.5",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^4.2.0",
    "node-pty": "^1.1.0"
  }
}
