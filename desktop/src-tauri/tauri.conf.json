{
  "productName": "dreamcontext",
  "version": "0.6.0",
  "identifier": "com.dreamcontext.desktop",
  "build": {
    "frontendDist": "./frontend-placeholder"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/<owner>/<repo>/releases/latest/download/latest.json"
      ],
      "pubkey": "<PLACEHOLDER — run: npm run tauri signer generate, add pubkey here, keep private key in CI secret>"
    }
  }
}
